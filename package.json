{
  "name": "ephemera",
  "version": "1.0.0",
  "description": "Generative decay art — stillness decays, movement restores.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "generative-art",
    "webcam",
    "decay",
    "electron"
  ],
  "author": "Ephemera",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.ephemera.decayart",
    "productName": "Ephemera",
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*"
    ]
  },
  "allowScripts": {
    "electron@30.5.1": true
  }
}
